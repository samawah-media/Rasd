NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Never expose these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
RASD_ADMIN_IMPORT_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=
PLATFORM_X_BEARER_TOKEN=
OPENAI_API_KEY=

# Server-only. Required for Vercel Cron endpoints under /api/cron/*.
# Use a long random value and set the same value in Vercel environment variables.
CRON_SECRET=

# Optional: improves TikTok/Instagram metadata extraction when yt-dlp is blocked.
APIFY_API_TOKEN=
APIFY_TIKTOK_PRIMARY_ACTOR=clockworks/free-tiktok-scraper
APIFY_TIKTOK_FALLBACK_ACTOR=OtzYfK1ndEGdwWFKQ/tiktok-scraper
APIFY_TIKTOK_USE_FALLBACK=true

# Local development only. Leave unset/false in production.
RASD_CONNECTOR_MOCKS=false
CONNECTOR_MOCK_MODE=false

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rasd-evidence
