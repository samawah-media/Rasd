    "supabase:legacy:dry-run": "powershell -ExecutionPolicy Bypass -File scripts/upsert_legacy_supabase.ps1",
    "supabase:legacy:upsert": "powershell -ExecutionPolicy Bypass -File scripts/upsert_legacy_supabase.ps1 -Execute"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
