{
  "name": "rasd-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "supabase:db:dry-run": "powershell -ExecutionPolicy Bypass -File scripts/apply_supabase_schema.ps1 -DryRun",
